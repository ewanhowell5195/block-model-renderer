{
  "multipart": [
    {
      "when": {"facing": "north", "has_book": "true"},
      "apply": {"model": "block-model-renderer:block/lectern_book"}
    },
    {
      "when": {"facing": "east", "has_book": "true"},
      "apply": {"model": "block-model-renderer:block/lectern_book", "y": 90}
    },
    {
      "when": {"facing": "south", "has_book": "true"},
      "apply": {"model": "block-model-renderer:block/lectern_book", "y": 180}
    },
    {
      "when": {"facing": "west", "has_book": "true"},
      "apply": {"model": "block-model-renderer:block/lectern_book", "y": 270}
    }
  ]
}
