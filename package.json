{
  "name": "block-model-renderer",
  "version": "2.0.0",
  "description": "Minecraft block and item model rendering for Node.js and the browser",
  "author": "Ewan Howell <ewanhowell5195>",
  "license": "MIT",
  "type": "module",
  "main": "./index.js",
  "jsdelivr": "./src/web.js",
  "exports": {
    ".": {
      "node": "./src/node.js",
      "default": "./src/web.js"
    }
  },
  "files": [
    "index.js",
    "src/",
    "assets/",
    "assets.zip",
    "docs/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ewanhowell5195/block-model-renderer.git"
  },
  "bugs": {
    "url": "https://github.com/ewanhowell5195/block-model-renderer/issues"
  },
  "keywords": [
    "minecraft",
    "render",
    "block",
    "item",
    "model",
    "resource-pack"
  ],
  "scripts": {
    "prepublishOnly": "node tools/build-assets.js",
    "build:assets": "node tools/build-assets.js",
    "generate": "node tools/generate/generate.js",
    "test": "node tools/generate/test.js",
    "example": "node examples/node/example.js",
    "all": "node examples/node/render_all.js",
    "animated": "node examples/node/render_animated.js",
    "fixed": "node examples/node/render_fixed.js",
    "overrides": "node examples/node/render_overrides.js",
    "simple": "node examples/node/render_simple.js",
    "full": "npm run example && npm run all && npm run animated && npm run fixed && npm run overrides && npm run simple && npm run loader",
    "loader": "node examples/node/render_loader.js"
  },
  "dependencies": {
    "gl": "^8.1.6",
    "headless-three": "^1.8.0",
    "sharp": "^0.34.5",
    "skia-canvas": "^3.0.8"
  },
  "peerDependencies": {
    "three": ">=0.152.0"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    }
  }
}
